\newlabel{sec:pusht_frontier}{{5.2}{16}{PushT Compression Frontier}{subsection.5.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces  \textsc  {PushT} closed-loop compression frontier. Success rates are measured over \(n=64\) episodes with seed \(0\). The teacher achieves \(95.31\%\) success. Compression has a stronger effect than in \textsc  {TwoRoom}; direct SVD baselines remain strongest at mild compression, while cache-only operator-aware fine-tuning is often harmful. }}{17}{figure.caption.7}\protected@file@percent }
\newlabel{fig:pusht-frontier}{{2}{17}{\textsc {PushT} closed-loop compression frontier. Success rates are measured over \(n=64\) episodes with seed \(0\). The teacher achieves \(95.31\%\) success. Compression has a stronger effect than in \textsc {TwoRoom}; direct SVD baselines remain strongest at mild compression, while cache-only operator-aware fine-tuning is often harmful}{figure.caption.7}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}Side-by-Side Frontier Comparison}{17}{subsection.5.3}\protected@file@percent }
