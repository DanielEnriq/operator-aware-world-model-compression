# Checkpoint artifacts (keep metadata/configs only)
checkpoints/**/*.pt
checkpoints/**/*.pth
checkpoints/**/*.ckpt
checkpoints/**/*.safetensors
checkpoints/**/wandb/
checkpoints/**/lightning_logs/

# Keep project checkpoint structure and reproducibility metadata in git
!checkpoints/README.md
!checkpoints/**/metadata.json
!checkpoints/**/config.yaml
!checkpoints/**/config.json
!checkpoints/**/.gitkeep
