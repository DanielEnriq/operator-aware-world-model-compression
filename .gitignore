*.pyc
.DS_Store

.venv/
.env
.ipynb_checkpoints/

outputs/*
!outputs/.gitkeep

artifacts/*
!artifacts/.gitkeep

data/
wandb/
mlruns/

*.pt
*.pth
*.ckpt
*.safetensors
*.h5
